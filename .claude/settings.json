{
  "mcpServers": {
    "browser-mcp": {
      "command": "node",
      "args": [
        "../../packages/browser-mcp/dist/index.js"
      ]
    },
    "runtime-mcp": {
      "command": "node",
      "args": [
        "../../packages/runtime-mcp/dist/server.js"
      ],
      "env": {
        "RUNTIME_BUILD_MODE": "lambda",
        "CH_ENTRY": "exp",
        "NODE_ENV": "production"
      }
    },
    "channel-mcp": {
      "command": "node",
      "args": [
        "../../packages/channel-mcp/dist/server.js"
      ]
    }
  }
}
