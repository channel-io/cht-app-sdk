{
  "name": "@channel.io/app-sdk-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "TypeScript SDK for building Channel.io apps",
  "repository": {
    "type": "git",
    "url": "https://github.com/channel-io/app-sdk.git"
  },
  "license": "MIT",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "typecheck": "turbo run typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "turbo run clean && rm -rf node_modules",
    "release": "pnpm changeset version && pnpm changeset publish",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.1",
    "@eslint/js": "^9.39.5",
    "@types/node": "^22.20.1",
    "eslint": "^9.39.5",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "prettier": "^3.9.6",
    "ts-proto": "^2.12.0",
    "turbo": "^2.10.5",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.65.0",
    "vitest": "^3.2.7"
  },
  "pnpm": {
    "overrides": {
      "ajv@<6.14.0": "6.15.0",
      "brace-expansion@^1.1.7": "1.1.15",
      "brace-expansion@^2.0.1": "2.1.1",
      "flatted@<3.4.2": "3.4.2",
      "form-data@>=4.0.0 <4.0.6": "4.0.6",
      "js-yaml@<3.15.0": "3.15.0",
      "js-yaml@>=4.0.0 <4.2.0": "4.2.0",
      "minimatch@<3.1.4": "3.1.5",
      "minimatch@>=9.0.0 <9.0.7": "9.0.9",
      "multer": "2.2.0",
      "picomatch@<2.3.2": "2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "4.0.5",
      "postcss": "8.5.16",
      "uuid@<11.1.1": "11.1.1",
      "ws@>=8.0.0 <8.21.0": "8.21.0",
      "yaml@>=2.0.0 <2.8.3": "2.9.0"
    }
  },
  "lint-staged": {
    "packages/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.{ts,tsx,js,jsx,json,md}": [
      "prettier --write"
    ]
  }
}
