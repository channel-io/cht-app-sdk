{
  "name": "@channel.io/app-sdk",
  "version": "0.16.1",
  "description": "CLI and main entry for Channel.io App SDK",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "channel-app": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@channel.io/app-sdk-core": "workspace:*",
    "@channel.io/app-sdk-server": "workspace:*",
    "@channel.io/app-sdk-wam": "workspace:*",
    "commander": "^12.1.0",
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/prompts": "^2.4.9",
    "typescript": "^5.7.2",
    "vitest": "^3.2.7"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/channel-io/cht-app-sdk.git",
    "directory": "ts/packages/cli"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
