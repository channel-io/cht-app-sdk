{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "lib": ["ES2022", "DOM"],
    "jsx": "react-jsx",
    "composite": true,
    "module": "ES2022",
    "moduleResolution": "bundler",
    "exactOptionalPropertyTypes": false
  },
  "include": ["src/**/*"],
  "exclude": ["src/__tests__/**"]
}
