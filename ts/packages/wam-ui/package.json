{
  "name": "@channel.io/app-sdk-wam-ui",
  "version": "0.2.2",
  "description": "UI components for Channel.io WAM — desk-consistent design patterns",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@channel.io/bezier-icons": ">=0.40.0",
    "@channel.io/bezier-react": ">=3.0.0 || >=4.0.0-next.0",
    "react": ">=17.0.0",
    "styled-components": ">=6.0.0"
  },
  "devDependencies": {
    "@channel.io/bezier-icons": "^0.59.0",
    "@channel.io/bezier-react": "^4.0.0-next.8",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "jsdom": "^25.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "styled-components": "^6.4.3",
    "typescript": "^5.7.2",
    "vitest": "^3.2.6"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/channel-io/cht-app-sdk.git",
    "directory": "ts/packages/wam-ui"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
