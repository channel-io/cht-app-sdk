{
  "name": "@channel.io/app-sdk-wam-ui",
  "version": "0.4.0",
  "description": "WAM-specific UI infrastructure and Bezier presets for Channel.io apps",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "peerDependencies": {
    "@channel.io/bezier-icons": ">=0.60.0 <1.0.0",
    "@channel.io/bezier-react": ">=4.0.0-next.13 <5.0.0",
    "react": ">=17.0.0",
    "styled-components": ">=6.0.0"
  },
  "devDependencies": {
    "@channel.io/bezier-icons": "^0.60.0",
    "@channel.io/bezier-react": "4.0.0-next.13",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "jsdom": "^25.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "styled-components": "^6.4.4",
    "typescript": "^5.7.2",
    "vitest": "^3.2.7"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/channel-io/app-sdk.git",
    "directory": "ts/packages/wam-ui"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
