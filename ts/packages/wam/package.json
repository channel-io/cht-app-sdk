{
  "name": "@channel.io/app-sdk-wam",
  "version": "0.16.1",
  "description": "React SDK for Channel.io WAM (Web App Module)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {},
  "peerDependencies": {
    "react": ">=17.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "react": "^18.3.1",
    "typescript": "^5.7.2",
    "vitest": "^3.2.6"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/channel-io/cht-app-sdk.git",
    "directory": "ts/packages/wam"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
