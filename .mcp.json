{
  "mcpServers": {
    "browser-mcp": {
      "type": "http",
      "url": "http://localhost:3000/mcp/browser"
    },
    "runtime-mcp": {
      "command": "node",
      "args": [
        "/app/packages/runtime-mcp/dist/server.js"
      ],
      "env": {
        "API_BASE_URL": "http://localhost:3000",
        "PROJECTS_DIR": "/app/generated",
        "RUNTIME_BUILD_MODE": "lambda",
        "CH_ENTRY": "exp",
        "NODE_ENV": "development",
        "APP_STUDIO_USER_ID": "dd498884-9d6c-41ce-9c4b-7d3ff40bf629",
        "APP_STUDIO_USER_EMAIL": "carol@channel.io"
      }
    },
    "channel-mcp": {
      "command": "node",
      "args": [
        "/app/packages/channel-mcp/dist/server.js"
      ],
      "env": {
        "API_BASE_URL": "http://localhost:3000"
      }
    }
  }
}
